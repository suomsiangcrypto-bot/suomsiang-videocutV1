{
  "name": "suomsiang-videocut",
  "version": "4.0.0",
  "description": "สุ่มเสียง VIDEOCUT — ตัดต่อวิดีโอ รวมคลิป ใส่เสียง ส่งออก MP4",
  "main": "main.js",
  "author": "Suomsiang",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.suomsiang.videocut",
    "productName": "สุ่มเสียง VIDEOCUT",
    "copyright": "Copyright © 2025 Suomsiang",
    "files": [
      "main.js",
      "editor.html",
      "editor.js",
      "ffmpeg.min.js",
      "ffmpeg-core.js",
      "ffmpeg-core.wasm",
      "ffmpeg-core.worker.js",
      "icons/**",
      "package.json",
      "preload.js",
      "node_modules/@ffmpeg-installer/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon256.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icons/icon256.png",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon256.png",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "สุ่มเสียง VIDEOCUT"
    },
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**"
    ]
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0"
  }
}