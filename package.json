{
  "name": "suomsiang-videocut",
  "version": "4.1.0",
  "description": "สุ่มเสียง VIDEOCUT",
  "main": "main.js",
  "author": "Suomsiang",
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.suomsiang.videocut",
    "productName": "suomsiang-videocut",
    "files": [
      "main.js",
      "preload.js",
      "editor.html",
      "editor.js",
      "ffmpeg.min.js",
      "ffmpeg-core.js",
      "ffmpeg-core.wasm",
      "ffmpeg-core.worker.js",
      "icons/**",
      "node_modules/@ffmpeg-installer/**"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**"
    ],
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "icons/icon256.png"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "icons/icon256.png",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "suomsiang-videocut"
    }
  }
}
